	keywords = {Computer Science - Machine Learning, Computer Science - Programming Languages, Computer Science - Artificial Intelligence},
	file = {Blondel and Roulet - 2024 - The Elements of Differentiable Programming.pdf:/home/tar/Zotero/storage/BHZIBES4/Blondel and Roulet - 2024 - The Elements of Differentiable Programming.pdf:application/pdf},
}

